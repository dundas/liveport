# LivePort Production Environment Variables
# Copy this file and set values in your deployment environment (e.g., Fly.io secrets)
# DO NOT commit actual values to git

# =============================================================================
# Database Configuration (mech-storage)
# =============================================================================

# Your mech-storage application ID
MECH_APPS_APP_ID=your-app-id

# Your mech-storage API key (keep secret!)
MECH_APPS_API_KEY=your-api-key

# Optional: Custom mech-storage API URL
# MECH_APPS_BASE_URL=https://api.mechdna.net

# =============================================================================
# Redis Configuration (Upstash)
# =============================================================================

# Redis connection URL (format: redis://user:password@host:port)
REDIS_URL=redis://default:your-password@your-redis-host.upstash.io:6379

# =============================================================================
# Authentication (Better Auth)
# =============================================================================

# Secret key for signing sessions (minimum 32 characters)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long

# Base URL of your dashboard (used for OAuth callbacks)
BETTER_AUTH_URL=https://app.liveport.dev

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# Tunnel Server Configuration
# =============================================================================

# Base domain for tunnel subdomains
TUNNEL_DOMAIN=liveport.dev

# Internal API secret for server-to-server communication
INTERNAL_API_SECRET=your-internal-api-secret

# Dashboard API URL (for tunnel server to validate keys)
DASHBOARD_API_URL=https://app.liveport.dev

# =============================================================================
# Error Monitoring (Sentry)
# =============================================================================

# Sentry DSN for error tracking
# SENTRY_DSN=https://your-key@sentry.io/your-project

# Sentry environment (production, staging, etc.)
# SENTRY_ENVIRONMENT=production

# =============================================================================
# Runtime Configuration
# =============================================================================

# Node environment (production, development, test)
NODE_ENV=production

# Port for the application (usually set by platform)
# PORT=3000

# =============================================================================
# Feature Flags
# =============================================================================

# Allow development keys without database validation (NEVER enable in production)
ALLOW_DEV_KEYS=false
