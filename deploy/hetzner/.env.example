# LivePort Tunnel Server Environment Variables
# Copy to /opt/liveport/.env on the server

NODE_ENV=production
PORT=8080
BASE_DOMAIN=liveport.online

# Database (mech-storage)
MECH_APPS_APP_ID=your_app_id
MECH_APPS_API_KEY=your_api_key
MECH_APPS_URL=https://storage.mechdna.net

# Redis (Upstash) — use rediss:// (TLS) for production Upstash connections
REDIS_URL=rediss://default:password@your-redis.upstash.io:6379

# Internal API secret for metering
INTERNAL_API_SECRET=your_random_secret_here
