{
  "name": "@liveport/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared utilities and types for LivePort",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.mjs",
      "require": "./dist/db/index.js"
    },
    "./db/migrations": {
      "types": "./dist/db/migrations/index.d.ts",
      "import": "./dist/db/migrations/index.mjs",
      "require": "./dist/db/migrations/index.js"
    },
    "./db/migrations/all": {
      "types": "./dist/db/migrations/all.d.ts",
      "import": "./dist/db/migrations/all.mjs",
      "require": "./dist/db/migrations/all.js"
    },
    "./redis": {
      "types": "./dist/redis/index.d.ts",
      "import": "./dist/redis/index.mjs",
      "require": "./dist/redis/index.js"
    },
    "./keys": {
      "types": "./dist/keys/index.d.ts",
      "import": "./dist/keys/index.mjs",
      "require": "./dist/keys/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.mjs",
      "require": "./dist/auth/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.mjs",
      "require": "./dist/crypto/index.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.mjs",
      "require": "./dist/logging/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.10.0",
    "better-auth": "^1.4.2",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.3.0",
    "nanoid": "^5.0.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "better-auth": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": true
    }
  }
}
