{
  "name": "@liveport/cli",
  "version": "0.1.0",
  "description": "CLI client for LivePort - secure localhost tunnels for AI agents",
  "bin": {
    "liveport": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cli",
    "tunnel",
    "localhost",
    "liveport",
    "ai-agents"
  ],
  "author": "",
