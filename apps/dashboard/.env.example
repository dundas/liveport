# LivePort Dashboard - Environment Variables
# Copy this file to .env.local for local development
# For production (Vercel), set these in the Vercel dashboard

# ============================================================================
# REQUIRED - Application will not start without these
# ============================================================================

# Database (mech-storage)
MECH_APPS_APP_ID=app_your_app_id_here
MECH_APPS_API_KEY=mk_your_api_key_here

# Authentication
BETTER_AUTH_SECRET=your_32_character_secret_here
BETTER_AUTH_URL=http://localhost:3001

# Internal API Authentication (must match tunnel server)
INTERNAL_API_SECRET=your_internal_api_secret_here

# Tunnel Server URL
TUNNEL_SERVER_URL=http://localhost:8080

# ============================================================================
# OPTIONAL - Application will work without these but with reduced functionality
# ============================================================================

# Admin User (for reference - role is set in database)
# To make a user admin, run: pnpm tsx packages/shared/scripts/make-admin.ts email@example.com
ADMIN_EMAIL=admin@example.com

# Redis - for rate limiting
# Local development: use local Redis or leave empty for in-memory fallback
REDIS_URL=
# REDIS_URL=redis://localhost:6379
# Production: use Upstash public Redis (Fly.io private Redis won't work from Vercel)
# REDIS_URL=redis://default:password@your-redis.upstash.io:6379

# Error Tracking (Sentry)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# OAuth (GitHub)
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# Email (CircleInbox) - Required for password reset and email verification
# Get API key from CircleInbox dashboard
# CIRCLEINBOX_API_KEY=ci_live_your_api_key_here
# EMAIL_FROM_ADDRESS=noreply@liveport.dev
# EMAIL_FROM_NAME=Liveport

# ============================================================================
# PRODUCTION NOTES (Vercel)
# ============================================================================
# 
# 1. Generate secrets:
#    - BETTER_AUTH_SECRET: openssl rand -base64 32
#    - INTERNAL_API_SECRET: openssl rand -hex 32 (must match tunnel server)
#
# 2. Set in Vercel Dashboard:
#    - Go to Project Settings > Environment Variables
#    - Add all required variables
#    - Set BETTER_AUTH_URL to your production URL (e.g., https://app.liveport.online)
#    - Set TUNNEL_SERVER_URL to tunnel server URL (e.g., https://liveport-tunnel.fly.dev)
#
# 3. Redis Connectivity:
#    - Fly.io Redis is private network only
#    - Use Upstash public Redis instance for production
#    - Or use Vercel KV (requires code changes)
#
# 4. Never commit .env.local to git!

# ================================================================
# STRIPE BILLING (Optional - enables paid subscriptions)
# ================================================================

# Stripe API Keys (get from https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create in Stripe Dashboard > Products)
# Tunnel Time: $0.005 per 1000 seconds (metered)
# STRIPE_PRICE_ID_TUNNEL_SECONDS=price_...
# Bandwidth: $0.05 per GB (metered)
# STRIPE_PRICE_ID_BANDWIDTH=price_...
# Static Subdomain: $2.50/month (optional)
# STRIPE_PRICE_ID_STATIC_SUBDOMAIN=price_...

# Stripe Webhook Secret (from Stripe Dashboard > Webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_...

# ================================================================
# STABLECOIN PAYMENTS
# ================================================================
# LivePort accepts stablecoins (USDC, USDP, USDG) via Stripe.
# To enable, go to Stripe Dashboard > Settings > Payment Methods
# and enable "Crypto" payment method.
#
# Supported networks: Ethereum, Solana, Polygon, Base
# Payments settle in USD to your Stripe balance.
#
# No additional configuration needed - just enable in Stripe Dashboard.
