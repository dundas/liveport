# LivePort Tunnel Server - Environment Variables
# Copy this file to .env.local for local development
# For production, set these as Fly.io secrets: fly secrets set KEY=value -a liveport-tunnel

# ============================================================================
# REQUIRED - Application will not start without these
# ============================================================================

# Database (mech-storage)
MECH_APPS_APP_ID=app_your_app_id_here
MECH_APPS_API_KEY=mk_your_api_key_here

# Server Configuration
PORT=8080
NODE_ENV=development
BASE_DOMAIN=localhost

# Internal API Authentication (must match dashboard)
INTERNAL_API_SECRET=your_internal_api_secret_here

# ============================================================================
# OPTIONAL - Application will work without these but with reduced functionality
# ============================================================================

# Redis - for rate limiting and heartbeats
# Local development: use local Redis or leave empty to disable rate limiting
REDIS_URL=
# REDIS_URL=redis://localhost:6379
# Production: use Upstash public Redis
# REDIS_URL=redis://default:password@your-redis.upstash.io:6379

# Error Tracking (Sentry)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Logging
LOG_LEVEL=info

# Development Mode - allows unregistered keys for testing
# WARNING: Never set this to true in production!
ALLOW_DEV_KEYS=false

# ============================================================================
# PRODUCTION NOTES
# ============================================================================
# 
# 1. Generate secrets:
#    - INTERNAL_API_SECRET: openssl rand -hex 32
#
# 2. Set in Fly.io:
#    fly secrets set MECH_APPS_APP_ID="app_xxx" -a liveport-tunnel
#    fly secrets set MECH_APPS_API_KEY="mk_xxx" -a liveport-tunnel
#    fly secrets set INTERNAL_API_SECRET="xxx" -a liveport-tunnel
#    fly secrets set REDIS_URL="redis://..." -a liveport-tunnel
#    fly secrets set BASE_DOMAIN="liveport.online" -a liveport-tunnel
#
# 3. Never commit .env.local to git!
