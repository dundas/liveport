{
  "name": "@liveport/tunnel-server",
  "version": "0.1.0",
  "private": true,
  "description": "LivePort tunnel server - LocalTunnel fork with bridge key auth",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js",
    "lint": "echo 'Skipping lint - ESLint not configured' && exit 0",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@liveport/shared": "workspace:*",
    "hono": "^4.10.7",
    "nanoid": "^5.0.0",
    "ws": "^8.16.0"
  }
}
