{
  "name": "liveport",
  "version": "0.1.0",
  "private": true,
  "description": "Secure localhost tunnels for AI agents",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "migrate": "tsx scripts/migrate.ts up",
    "migrate:status": "tsx scripts/migrate.ts status",
    "migrate:rollback": "tsx scripts/migrate.ts rollback"
  },
  "keywords": [
    "tunnel",
    "localhost",
    "ai-agents",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.10.0",
    "dotenv": "^17.2.3",
    "playwright": "^1.57.0",
    "prettier": "^3.1.0",
    "tsx": "^4.20.6",
    "turbo": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
